# Copy this file to scripts/deploy.env (gitignored) and fill in real values.
# The same values are configured as GitHub repo variables for CI (OIDC).
# NEVER commit the real scripts/deploy.env — no account IDs / ARNs in the repo.

AWS_PROFILE=your-cli-profile
AWS_REGION=us-east-1

# Bucket follows <name>-<account-id>; created during hosting setup (see docs/deployment.md).
S3_BUCKET=felipeflorez-dev-REPLACE_ACCOUNT_ID
CLOUDFRONT_DISTRIBUTION_ID=REPLACE_ME

# Used by CI (OIDC). Local manual deploys use AWS_PROFILE instead.
AWS_ROLE_ARN=arn:aws:iam::REPLACE_ACCOUNT_ID:role/felipeflorez-dev-deploy

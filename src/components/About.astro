---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="about" class="mx-auto max-w-6xl scroll-mt-20 px-6 py-20 sm:py-28">
  <p
    data-reveal
    class="font-mono text-xs tracking-widest text-accent uppercase"
  >
    {t("about.eyebrow")}
  </p>
  <div class="mt-6 grid gap-10 lg:grid-cols-[1fr_1.1fr] lg:gap-16">
    <h2
      data-reveal
      class="text-3xl font-semibold tracking-tight text-balance sm:text-4xl"
    >
      {t("about.heading")}
    </h2>
    <div class="space-y-5 text-lg leading-relaxed text-muted text-pretty">
      <p data-reveal>{t("about.p1")}</p>
      <p data-reveal>{t("about.p2")}</p>
    </div>
  </div>
</section>

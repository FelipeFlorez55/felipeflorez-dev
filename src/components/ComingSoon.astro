---
// Placeholder home content (localized). Sections are built from specs/ — see
// specs/landing.md. First spec to implement: hero + metrics bar.
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import LanguageToggle from "./LanguageToggle.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<main class="mx-auto flex min-h-screen max-w-3xl flex-col justify-center px-6">
  <div class="mb-10"><LanguageToggle /></div>
  <p class="font-mono text-sm tracking-widest text-faint uppercase">
    {t("hero.kicker")}
  </p>
  <h1 class="mt-4 text-4xl font-semibold tracking-tight text-balance sm:text-5xl">
    {t("hero.heading")}
  </h1>
  <p class="mt-4 max-w-prose text-lg text-muted">{t("hero.subcopy")}</p>
  <div class="mt-8">
    <a
      href="/felipe-florez-cv.pdf"
      download
      class="text-accent underline-offset-4 hover:underline">{t("cv.download")} ↓</a
    >
  </div>
</main>

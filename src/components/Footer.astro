---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const links = [
  { label: t("footer.email"), href: "mailto:pipeflorez_99@hotmail.com" },
  {
    label: t("footer.linkedin"),
    href: "https://www.linkedin.com/in/andres-felipe-florez-gil",
  },
  { label: t("footer.github"), href: "https://github.com/FelipeFlorez55" },
];

const year = 2026;
---

<footer class="border-t border-border/60">
  <div
    class="mx-auto flex max-w-6xl flex-col gap-6 px-6 py-12 sm:flex-row sm:items-end sm:justify-between"
  >
    <div>
      <p class="font-mono text-sm tracking-tight text-ink">
        Felipe<span class="text-faint">.</span>Florez
      </p>
      <p class="mt-1 text-sm text-muted">{t("footer.role")}</p>
      <p class="mt-3 text-xs text-faint">{t("footer.builtWith")}</p>
    </div>
    <nav class="flex flex-wrap gap-5" aria-label="Social links">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="font-mono text-xs tracking-widest text-faint uppercase transition-colors hover:text-ink"
            target={l.href.startsWith("http") ? "_blank" : undefined}
            rel={l.href.startsWith("http") ? "noopener noreferrer" : undefined}
          >
            {l.label}
          </a>
        ))
      }
    </nav>
  </div>
  <div class="mx-auto max-w-6xl px-6 pb-8">
    <p class="text-xs text-faint">© {year} Andres Felipe Florez Gil</p>
  </div>
</footer>
